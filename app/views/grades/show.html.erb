<% content_for :breadcrumbs do %>
  <span class="text-gray-600"><%= @grade.title %></span>
<% end %>

<h1 class="text-2xl font-bold mb-6"><%= @grade.title %></h1>

<div class="space-y-6">
  <% @content_modules.each do |cm| %>
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h2 class="text-lg font-semibold mb-2">
        <%= link_to "Module #{cm.number}: #{cm.title}",
              grade_content_module_path(@grade, cm),
              class: "text-indigo-700 hover:underline" %>
      </h2>
      <p class="text-sm text-gray-500">
        <%= cm.topics.count %> topics &middot;
        <%= cm.topics.sum { |t| t.lessons.size } %> lessons
      </p>
    </div>
  <% end %>
</div>
